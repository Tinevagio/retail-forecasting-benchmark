cat > .gitattributes << 'EOF'
# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.pdf binary
*.zip binary
*.parquet binary
*.csv binary
EOF
